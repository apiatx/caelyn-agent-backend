modules = ["python-3.11"]
[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[nix]
packages = ["psmisc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/backend && python3.11 -m uvicorn main:app --host 0.0.0.0 --port 5000"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; cd /home/runner/workspace/backend && python3.11 -m uvicorn main:app --host 0.0.0.0 --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd /home/runner/workspace/backend && python3.11 -m gunicorn -w 1 -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:5000 --timeout 120 main:app"]

[userenv]

[userenv.shared]
